---
export const prerender = false;

import { env } from "cloudflare:workers";
import Base from "@/layouts/Base.astro";
import {
  readUserHash,
  setUserHashCookie,
  clearUserHashCookie,
} from "@/lib/cookie";
import {
  readCfAccessEmail,
  getLinkedHash,
  linkEmailToHash,
  unlinkEmail,
} from "@/lib/links";

const cfEmail = readCfAccessEmail(Astro.request);
const domain = env.DOMAIN ?? "your-proxy";

let error: string | null = null;
let justCleared = false;
let justSaved = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action");
  if (action === "clear") {
    if (cfEmail) await unlinkEmail(env.SESSION, cfEmail);
    Astro.response.headers.append("Set-Cookie", clearUserHashCookie());
    justCleared = true;
  } else {
    const raw = String(form.get("user_hash") ?? "").trim();
    if (!/^[0-9a-f]{16}$/.test(raw)) {
      error = "user_hash must be exactly 16 hex characters";
    } else {
      if (cfEmail) await linkEmailToHash(env.SESSION, cfEmail, raw);
      // Astro.redirect() drops headers previously set on Astro.response,
      // so construct the redirect Response inline.
      return new Response(null, {
        status: 302,
        headers: {
          Location: "/",
          "Set-Cookie": setUserHashCookie(raw),
        },
      });
    }
  }
}

const cookieHash = readUserHash(Astro.request.headers.get("cookie"));
const linkedHash = await getLinkedHash(env.SESSION, cfEmail);
const current = linkedHash ?? cookieHash;
---

<Base title="llmetry — setup">
  <div class="max-w-xl">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Link your account</h1>
    <p class="text-[var(--color-muted-foreground)] mb-6 leading-relaxed">
      The proxy writes each of your Claude Code transactions into a private SQLite database keyed by a <span class="text-[var(--color-foreground)]">user_hash</span>. Paste yours here and this browser (plus anywhere else you sign in as {cfEmail ?? "this account"}) will show just your data.
    </p>

    {
      cfEmail && (
        <p class="text-xs text-[var(--color-subtle-foreground)] mb-6">
          Signed in via Cloudflare Access as <span class="text-[var(--color-foreground)] font-mono">{cfEmail}</span>. Saving will store the link durably so future sessions are automatic.
        </p>
      )
    }

    <details class="mb-6 text-sm text-[var(--color-muted-foreground)]">
      <summary class="cursor-pointer hover:text-[var(--color-foreground)]">
        How do I find my user_hash?
      </summary>
      <pre class="bg-[var(--color-card)] mt-3 p-4 rounded-lg text-xs overflow-x-auto border border-[var(--color-border)]"><code>{`# with your Claude Code OAuth bearer or API key:
curl -H "Authorization: Bearer <token>" https://${domain}/_cm/whoami

# example response:
# {"user_hash":"0203addab2792724"}`}</code></pre>
    </details>

    {
      error && (
        <div class="mb-4 p-3 rounded-lg border border-[var(--color-warn-muted)] bg-[var(--color-warn-muted)] text-[var(--color-warn)] text-sm">
          {error}
        </div>
      )
    }
    {
      justCleared && !error && (
        <div class="mb-4 p-3 rounded-lg border border-[var(--color-good-muted)] bg-[var(--color-good-muted)] text-[var(--color-good)] text-sm">
          Link cleared.
        </div>
      )
    }

    <form method="POST" class="flex flex-col gap-3 mb-8">
      <label class="text-sm text-[var(--color-muted-foreground)]" for="user_hash">
        user_hash
      </label>
      <input
        id="user_hash"
        name="user_hash"
        autocomplete="off"
        spellcheck="false"
        placeholder="0203addab2792724"
        value={current ?? ""}
        class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-lg px-3 py-2 font-mono focus:outline-none focus:border-[var(--color-border-strong)]"
      />
      <div class="flex gap-2">
        <button
          type="submit"
          class="bg-[var(--color-money)] text-[var(--color-background)] px-4 py-2 rounded-lg font-medium hover:opacity-90"
        >
          Save
        </button>
        {
          current && (
            <button
              type="submit"
              name="action"
              value="clear"
              class="border border-[var(--color-border)] px-4 py-2 rounded-lg hover:bg-[var(--color-card)]"
            >
              Clear
            </button>
          )
        }
      </div>
    </form>

    {
      current && (
        <p class="text-sm text-[var(--color-muted-foreground)]">
          Currently viewing: <code class="font-mono text-[var(--color-foreground)]">{current}</code>
          {linkedHash && (
            <span class="text-[var(--color-subtle-foreground)] ml-2">
              (linked to your Google account)
            </span>
          )}
        </p>
      )
    }
  </div>
</Base>
